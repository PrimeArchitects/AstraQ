{
  "name": "astrasphere-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@radix-ui/react-slot": "1.1.1",
    "@tanstack/react-query": "5.62.11",
    "@tanstack/react-query-devtools": "5.62.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0",
    "lucide-react": "0.469.0",
    "next-themes": "0.4.4",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@eslint/eslintrc": "3.2.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "tailwindcss": "3.4.17",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.18",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "vitest": "2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
